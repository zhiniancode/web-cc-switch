NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# 管理员密码。生产环境请务必修改。
ADMIN_PASSWORD=change-this-password

# 会话 HMAC 密钥。生产环境请务必设置为长随机串。
SESSION_SECRET=change-this-session-secret

# 会话时长，默认 12 小时。
SESSION_TTL_SECONDS=43200

# 登录限流
LOGIN_WINDOW_MS=600000
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_MS=900000

# 允许跨源写请求的 Origin，逗号分隔。默认只允许当前 Host。
# ALLOWED_ORIGINS=https://config.everso.top

# 备份保留数量
LIVE_BACKUP_RETENTION=60

# 反向代理场景下获取真实 IP
TRUST_PROXY=loopback, linklocal, uniquelocal
