[Unit]
Description=CC Switch Web
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/web-cc-switch
EnvironmentFile=/root/web-cc-switch/.env
ExecStart=/usr/bin/env node /root/web-cc-switch/dist/server/server/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
